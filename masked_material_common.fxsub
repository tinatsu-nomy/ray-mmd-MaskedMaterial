// ==================== Common Settings Defaults ====================

#ifndef ALPHA_MAP_FROM
    #define ALPHA_MAP_FROM 3
#endif
#ifndef ALPHA_MAP_SWIZZLE
    #define ALPHA_MAP_SWIZZLE 3
#endif
// Mask packing mode: 0 = individual grayscale, 1 = RGB packed (2 textures)
#ifndef MASK_PACKING
    #define MASK_PACKING 0
#endif

#if MASK_PACKING == 0
    // --- Individual mask files (1 grayscale per layer) ---
    #ifndef MASK_1_FILE
        #define MASK_1_FILE "masks/mask_1.png"
    #endif
    #ifndef MASK_2_FILE
        #define MASK_2_FILE "masks/mask_2.png"
    #endif
    #ifndef MASK_3_FILE
        #define MASK_3_FILE "masks/mask_3.png"
    #endif
    #ifndef MASK_4_FILE
        #define MASK_4_FILE "masks/mask_4.png"
    #endif
    #ifndef MASK_5_FILE
        #define MASK_5_FILE "masks/mask_5.png"
    #endif
    #ifndef MASK_6_FILE
        #define MASK_6_FILE "masks/mask_6.png"
    #endif
    #ifndef MASK_7_FILE
        #define MASK_7_FILE "masks/mask_7.png"
    #endif
#else
    // --- RGBA packed mask files ---
    // Tex A: R=mask1, G=mask2, B=mask3, A=mask4
    // Tex B: R=mask5, G=mask6, B=mask7, A=(unused)
    #ifndef MASK_PACKED_A_FILE
        #define MASK_PACKED_A_FILE "masks/mask_packed_a.png"
    #endif
    #ifndef MASK_PACKED_B_FILE
        #define MASK_PACKED_B_FILE "masks/mask_packed_b.png"
    #endif
#endif

// ==================== Uniform Declarations ====================

float4x4 matWorldView     : WORLDVIEW;
float4x4 matWorldViewProject : WORLDVIEWPROJECTION;

float4 MaterialDiffuse  : DIFFUSE  <string Object = "Geometry";>;
float4 MaterialAmbient  : EMISSIVE <string Object = "Geometry";>;
float4 MaterialSpecular : SPECULAR <string Object = "Geometry";>;
float  MaterialPower    : SPECULARPOWER <string Object = "Geometry";>;

bool use_texture;
bool use_subtexture;
bool use_spheremap;
bool use_toon;

// ==================== G-Buffer Shared Render Targets ====================

shared texture Gbuffer2RT : RENDERCOLORTARGET;
shared texture Gbuffer3RT : RENDERCOLORTARGET;
shared texture Gbuffer4RT : RENDERCOLORTARGET;
shared texture Gbuffer5RT : RENDERCOLORTARGET;
shared texture Gbuffer6RT : RENDERCOLORTARGET;
shared texture Gbuffer7RT : RENDERCOLORTARGET;
shared texture Gbuffer8RT : RENDERCOLORTARGET;

// ==================== Model Texture ====================

texture DiffuseMap : MATERIALTEXTURE;
sampler DiffuseMapSamp = sampler_state
{
    texture = <DiffuseMap>;
    MINFILTER = LINEAR; MAGFILTER = LINEAR; MIPFILTER = LINEAR;
    ADDRESSU = WRAP; ADDRESSV = WRAP;
};

// ==================== Mask Textures ====================

#if MASK_PACKING == 0
    // --- Individual grayscale masks ---
    #if LAYER_COUNT > 1
    texture MaskTex1<string ResourceName = MASK_1_FILE;>;
    sampler MaskSamp1 = sampler_state {
        texture = <MaskTex1>;
        MINFILTER = LINEAR; MAGFILTER = LINEAR; MIPFILTER = NONE;
        ADDRESSU = CLAMP; ADDRESSV = CLAMP;
    };
    #endif

    #if LAYER_COUNT > 2
    texture MaskTex2<string ResourceName = MASK_2_FILE;>;
    sampler MaskSamp2 = sampler_state {
        texture = <MaskTex2>;
        MINFILTER = LINEAR; MAGFILTER = LINEAR; MIPFILTER = NONE;
        ADDRESSU = CLAMP; ADDRESSV = CLAMP;
    };
    #endif

    #if LAYER_COUNT > 3
    texture MaskTex3<string ResourceName = MASK_3_FILE;>;
    sampler MaskSamp3 = sampler_state {
        texture = <MaskTex3>;
        MINFILTER = LINEAR; MAGFILTER = LINEAR; MIPFILTER = NONE;
        ADDRESSU = CLAMP; ADDRESSV = CLAMP;
    };
    #endif

    #if LAYER_COUNT > 4
    texture MaskTex4<string ResourceName = MASK_4_FILE;>;
    sampler MaskSamp4 = sampler_state {
        texture = <MaskTex4>;
        MINFILTER = LINEAR; MAGFILTER = LINEAR; MIPFILTER = NONE;
        ADDRESSU = CLAMP; ADDRESSV = CLAMP;
    };
    #endif

    #if LAYER_COUNT > 5
    texture MaskTex5<string ResourceName = MASK_5_FILE;>;
    sampler MaskSamp5 = sampler_state {
        texture = <MaskTex5>;
        MINFILTER = LINEAR; MAGFILTER = LINEAR; MIPFILTER = NONE;
        ADDRESSU = CLAMP; ADDRESSV = CLAMP;
    };
    #endif

    #if LAYER_COUNT > 6
    texture MaskTex6<string ResourceName = MASK_6_FILE;>;
    sampler MaskSamp6 = sampler_state {
        texture = <MaskTex6>;
        MINFILTER = LINEAR; MAGFILTER = LINEAR; MIPFILTER = NONE;
        ADDRESSU = CLAMP; ADDRESSV = CLAMP;
    };
    #endif

    #if LAYER_COUNT > 7
    texture MaskTex7<string ResourceName = MASK_7_FILE;>;
    sampler MaskSamp7 = sampler_state {
        texture = <MaskTex7>;
        MINFILTER = LINEAR; MAGFILTER = LINEAR; MIPFILTER = NONE;
        ADDRESSU = CLAMP; ADDRESSV = CLAMP;
    };
    #endif

#else
    // --- RGBA packed masks ---
    // Tex A (R=mask1, G=mask2, B=mask3, A=mask4) — needed when LAYER_COUNT > 1
    #if LAYER_COUNT > 1
    texture MaskPackedTexA<string ResourceName = MASK_PACKED_A_FILE;>;
    sampler MaskPackedSampA = sampler_state {
        texture = <MaskPackedTexA>;
        MINFILTER = LINEAR; MAGFILTER = LINEAR; MIPFILTER = NONE;
        ADDRESSU = CLAMP; ADDRESSV = CLAMP;
    };
    #endif

    // Tex B (R=mask5, G=mask6, B=mask7) — needed when LAYER_COUNT > 5
    #if LAYER_COUNT > 5
    texture MaskPackedTexB<string ResourceName = MASK_PACKED_B_FILE;>;
    sampler MaskPackedSampB = sampler_state {
        texture = <MaskPackedTexB>;
        MINFILTER = LINEAR; MAGFILTER = LINEAR; MIPFILTER = NONE;
        ADDRESSU = CLAMP; ADDRESSV = CLAMP;
    };
    #endif
#endif

// ==================== Per-Layer Textures ====================
// Declare texture + sampler only when _MAP_FROM == 1
// Sampler config: WRAP + LINEAR (standard for texture maps)

#define DECLARE_LAYER_TEX(name, file) \
    texture name<string ResourceName = file;>; \
    sampler name##Samp = sampler_state { \
        texture = <name>; \
        MINFILTER = LINEAR; MAGFILTER = LINEAR; MIPFILTER = LINEAR; \
        ADDRESSU = WRAP; ADDRESSV = WRAP; \
    };

