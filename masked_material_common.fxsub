// ==================== Structures ====================

struct MaterialParam
{
    float3 normal;
    float3 albedo;
    float3 specular;
    float3 emissive;
    float  smoothness;
    float  metalness;
    float  emissiveIntensity;
    float  alpha;
    float  visibility;
    float  customDataA;
    float3 customDataB;
    int    lightModel;
};

struct GbufferParam
{
    float4 buffer1 : COLOR0;
    float4 buffer2 : COLOR1;
    float4 buffer3 : COLOR2;
    float4 buffer4 : COLOR3;
};

// ==================== Utility Functions ====================

float3 EncodeNormal(float3 normal)
{
    float p = sqrt(-normal.z * 8 + 8);
    float2 enc = normal.xy / p + 0.5f;
    float2 enc255 = enc * 255;
    float2 residual = floor(frac(enc255) * 16);
    return float3(floor(enc255), residual.x * 16 + residual.y) / 255;
}

float luminance(float3 rgb)
{
    return dot(rgb, float3(0.299, 0.587, 0.114));
}

float3 srgb2linear(float3 rgb)
{
    return pow(max(abs(rgb), 1e-5), 2.2);
}

float srgb2linear_scalar(float v)
{
    return pow(max(abs(v), 1e-5), 2.2);
}

float SmoothnessToRoughness(float smoothness)
{
    return (1.0f - smoothness) * (1.0f - smoothness);
}

float3 RNMBlendUnpacked(float3 n1, float3 n2)
{
    n1 += float3( 0,  0, 1);
    n2 *= float3(-1, -1, 1);
    return normalize(n1 * dot(n1, n2) / n1.z - n2);
}

// ==================== G-Buffer Encode ====================

GbufferParam EncodeGbufferMasked(MaterialParam material, float linearDepth)
{
    GbufferParam gbuffer;

    gbuffer.buffer1.xyz = material.albedo * (1 - material.metalness);
    gbuffer.buffer1.w   = material.smoothness;

    float3 viewNormal = mul(material.normal, (float3x3)matWorldView);
    viewNormal = normalize(viewNormal);

    gbuffer.buffer2.xyz = EncodeNormal(viewNormal);
    gbuffer.buffer2.w   = material.customDataA;

    gbuffer.buffer3.xyz = lerp(material.specular, max(0.02, material.albedo), material.metalness);
    gbuffer.buffer3.w   = 0;

    if (material.lightModel != SHADINGMODELID_DEFAULT)
    {
        if (material.lightModel == SHADINGMODELID_EMISSIVE)
        {
            material.customDataB = material.emissive;
        }
        else if (material.lightModel != SHADINGMODELID_GLASS)
        {
            material.customDataB *= (1 - material.metalness);
        }
        gbuffer.buffer3 = float4(luminance(gbuffer.buffer3.xyz), material.customDataB);
    }

    gbuffer.buffer4 = float4(linearDepth, material.emissiveIntensity, material.visibility, material.lightModel);
    gbuffer.buffer4.w += material.alpha * MAX_FRACTIONAL_8_BIT;

    return gbuffer;
}

// ==================== TBN Computation ====================

float3 ComputeTangentBinormalNormal(float3 N, float3 P, float2 coord, float3 tangentNormal)
{
    float3 dp1 = ddx(P);
    float3 dp2 = ddy(P);
    float2 duv1 = ddx(coord);
    float2 duv2 = ddy(coord);

    float3x3 M = float3x3(dp1, dp2, N);
    float2x3 I = float2x3(cross(M[1], M[2]), cross(M[2], M[0]));
    float3 T = mul(float2(duv1.x, duv2.x), I);
    float3 B = mul(float2(duv1.y, duv2.y), I);

    float scaleT = 1.0f / (dot(T, T) + 1e-6);
    float scaleB = 1.0f / (dot(B, B) + 1e-6);

    float3x3 tbnTransform;
    tbnTransform[0] =  normalize(T * scaleT);
    tbnTransform[1] = -normalize(B * scaleB);
    tbnTransform[2] =  N;

    return normalize(mul(tangentNormal, tbnTransform));
}

// ==================== Scalar Map Swizzle Helper ====================

#define SWIZZLE_SCALAR(val4, swiz) \
    ((swiz) == 1 ? (val4).g : ((swiz) == 2 ? (val4).b : ((swiz) == 3 ? (val4).a : (val4).r)))

// ==================== Per-Layer Albedo Sampling Macros ====================
// FROM=0: constant color (if APPLY_DIFFUSE=1, multiply by model texture)
// FROM=1: external texture x tint

#define CALC_LAYER_ALBEDO(N, baseTex) _CALC_LAYER_ALBEDO_##N(baseTex)

#if L0_ALBEDO_MAP_FROM == 1
    #define _CALC_LAYER_ALBEDO_0(baseTex) \
        (srgb2linear(tex2D(L0_AlbedoTexSamp, coord).rgb) * srgb2linear((float3)L0_ALBEDO))
#elif L0_ALBEDO_APPLY_DIFFUSE
    #define _CALC_LAYER_ALBEDO_0(baseTex) \
        ((baseTex) * srgb2linear((float3)L0_ALBEDO))
#else
    #define _CALC_LAYER_ALBEDO_0(baseTex) \
        (srgb2linear((float3)L0_ALBEDO))
#endif

#if L1_ALBEDO_MAP_FROM == 1
    #define _CALC_LAYER_ALBEDO_1(baseTex) \
        (srgb2linear(tex2D(L1_AlbedoTexSamp, coord).rgb) * srgb2linear((float3)L1_ALBEDO))
#elif L1_ALBEDO_APPLY_DIFFUSE
    #define _CALC_LAYER_ALBEDO_1(baseTex) \
        ((baseTex) * srgb2linear((float3)L1_ALBEDO))
#else
    #define _CALC_LAYER_ALBEDO_1(baseTex) \
        (srgb2linear((float3)L1_ALBEDO))
#endif

#if L2_ALBEDO_MAP_FROM == 1
