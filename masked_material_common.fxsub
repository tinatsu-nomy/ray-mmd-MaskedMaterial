    #define _CALC_LAYER_TN_5(c) \
        RNMBlendUnpacked( \
            _sampleNormalMap(L5_NormalTexSamp, c, L5_NORMAL_MAP_LOOP, L5_NORMAL_MAP_SCALE, L5_NORMAL_MAP_TYPE), \
