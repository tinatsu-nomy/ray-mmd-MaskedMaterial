// ==================== Per-Layer Normal Sampling Macros ====================
// Returns tangent-space normal for each layer (no normal map = 0,0,1)
// When both NORMAL + NORMAL_SUB are present, composed via RNMBlend

#define CALC_LAYER_TANGENT_NORMAL(N) _CALC_LAYER_TN_##N(coord)

// Normal map sampling helper
#define _SAMPLE_NORMAL_RGB(samp, c, loop, scale, type) \
    _sampleNormalRGB(samp, c, loop, scale, type)

// ---- Layer 0 Normal ----
#if L0_NORMAL_MAP_FROM == 1 && L0_NORMAL_SUB_MAP_FROM == 1
    #define _CALC_LAYER_TN_0(c) \
        RNMBlendUnpacked( \
            _sampleNormalMap(L0_NormalTexSamp, c, L0_NORMAL_MAP_LOOP, L0_NORMAL_MAP_SCALE, L0_NORMAL_MAP_TYPE), \
            _sampleNormalMap(L0_NormalSubTexSamp, c, L0_NORMAL_SUB_MAP_LOOP, L0_NORMAL_SUB_MAP_SCALE, L0_NORMAL_SUB_MAP_TYPE))
#elif L0_NORMAL_MAP_FROM == 1
    #define _CALC_LAYER_TN_0(c) \
        _sampleNormalMap(L0_NormalTexSamp, c, L0_NORMAL_MAP_LOOP, L0_NORMAL_MAP_SCALE, L0_NORMAL_MAP_TYPE)
#elif L0_NORMAL_SUB_MAP_FROM == 1
    #define _CALC_LAYER_TN_0(c) \
        _sampleNormalMap(L0_NormalSubTexSamp, c, L0_NORMAL_SUB_MAP_LOOP, L0_NORMAL_SUB_MAP_SCALE, L0_NORMAL_SUB_MAP_TYPE)
#else
    #define _CALC_LAYER_TN_0(c) float3(0, 0, 1)
#endif

// ---- Layer 1 Normal ----
#if L1_NORMAL_MAP_FROM == 1 && L1_NORMAL_SUB_MAP_FROM == 1
    #define _CALC_LAYER_TN_1(c) \
        RNMBlendUnpacked( \
            _sampleNormalMap(L1_NormalTexSamp, c, L1_NORMAL_MAP_LOOP, L1_NORMAL_MAP_SCALE, L1_NORMAL_MAP_TYPE), \
            _sampleNormalMap(L1_NormalSubTexSamp, c, L1_NORMAL_SUB_MAP_LOOP, L1_NORMAL_SUB_MAP_SCALE, L1_NORMAL_SUB_MAP_TYPE))
#elif L1_NORMAL_MAP_FROM == 1
    #define _CALC_LAYER_TN_1(c) \
        _sampleNormalMap(L1_NormalTexSamp, c, L1_NORMAL_MAP_LOOP, L1_NORMAL_MAP_SCALE, L1_NORMAL_MAP_TYPE)
#elif L1_NORMAL_SUB_MAP_FROM == 1
    #define _CALC_LAYER_TN_1(c) \
        _sampleNormalMap(L1_NormalSubTexSamp, c, L1_NORMAL_SUB_MAP_LOOP, L1_NORMAL_SUB_MAP_SCALE, L1_NORMAL_SUB_MAP_TYPE)
#else
    #define _CALC_LAYER_TN_1(c) float3(0, 0, 1)
#endif

// ---- Layer 2 Normal ----
#if L2_NORMAL_MAP_FROM == 1 && L2_NORMAL_SUB_MAP_FROM == 1
    #define _CALC_LAYER_TN_2(c) \
        RNMBlendUnpacked( \
            _sampleNormalMap(L2_NormalTexSamp, c, L2_NORMAL_MAP_LOOP, L2_NORMAL_MAP_SCALE, L2_NORMAL_MAP_TYPE), \
            _sampleNormalMap(L2_NormalSubTexSamp, c, L2_NORMAL_SUB_MAP_LOOP, L2_NORMAL_SUB_MAP_SCALE, L2_NORMAL_SUB_MAP_TYPE))
#elif L2_NORMAL_MAP_FROM == 1
    #define _CALC_LAYER_TN_2(c) \
        _sampleNormalMap(L2_NormalTexSamp, c, L2_NORMAL_MAP_LOOP, L2_NORMAL_MAP_SCALE, L2_NORMAL_MAP_TYPE)
#elif L2_NORMAL_SUB_MAP_FROM == 1
