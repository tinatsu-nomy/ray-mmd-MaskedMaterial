#if L6_NORMAL_MAP_FROM == 1 && L6_NORMAL_SUB_MAP_FROM == 1
    #define _CALC_LAYER_TN_6(c) \
        RNMBlendUnpacked( \
            _sampleNormalMap(L6_NormalTexSamp, c, L6_NORMAL_MAP_LOOP, L6_NORMAL_MAP_SCALE, L6_NORMAL_MAP_TYPE), \
            _sampleNormalMap(L6_NormalSubTexSamp, c, L6_NORMAL_SUB_MAP_LOOP, L6_NORMAL_SUB_MAP_SCALE, L6_NORMAL_SUB_MAP_TYPE))
#elif L6_NORMAL_MAP_FROM == 1
    #define _CALC_LAYER_TN_6(c) \
        _sampleNormalMap(L6_NormalTexSamp, c, L6_NORMAL_MAP_LOOP, L6_NORMAL_MAP_SCALE, L6_NORMAL_MAP_TYPE)
#elif L6_NORMAL_SUB_MAP_FROM == 1
    #define _CALC_LAYER_TN_6(c) \
        _sampleNormalMap(L6_NormalSubTexSamp, c, L6_NORMAL_SUB_MAP_LOOP, L6_NORMAL_SUB_MAP_SCALE, L6_NORMAL_SUB_MAP_TYPE)
#else
    #define _CALC_LAYER_TN_6(c) float3(0, 0, 1)
#endif

#if L7_NORMAL_MAP_FROM == 1 && L7_NORMAL_SUB_MAP_FROM == 1
    #define _CALC_LAYER_TN_7(c) \
        RNMBlendUnpacked( \
            _sampleNormalMap(L7_NormalTexSamp, c, L7_NORMAL_MAP_LOOP, L7_NORMAL_MAP_SCALE, L7_NORMAL_MAP_TYPE), \
            _sampleNormalMap(L7_NormalSubTexSamp, c, L7_NORMAL_SUB_MAP_LOOP, L7_NORMAL_SUB_MAP_SCALE, L7_NORMAL_SUB_MAP_TYPE))
#elif L7_NORMAL_MAP_FROM == 1
    #define _CALC_LAYER_TN_7(c) \
        _sampleNormalMap(L7_NormalTexSamp, c, L7_NORMAL_MAP_LOOP, L7_NORMAL_MAP_SCALE, L7_NORMAL_MAP_TYPE)
#elif L7_NORMAL_SUB_MAP_FROM == 1
    #define _CALC_LAYER_TN_7(c) \
        _sampleNormalMap(L7_NormalSubTexSamp, c, L7_NORMAL_SUB_MAP_LOOP, L7_NORMAL_SUB_MAP_SCALE, L7_NORMAL_SUB_MAP_TYPE)
#else
    #define _CALC_LAYER_TN_7(c) float3(0, 0, 1)
#endif

// Whether any layer has a normal map enabled
#define _ANY_NORMAL_MAP \
    (L0_NORMAL_MAP_FROM || L0_NORMAL_SUB_MAP_FROM || \
     L1_NORMAL_MAP_FROM || L1_NORMAL_SUB_MAP_FROM || \
     L2_NORMAL_MAP_FROM || L2_NORMAL_SUB_MAP_FROM || \
     L3_NORMAL_MAP_FROM || L3_NORMAL_SUB_MAP_FROM || \
     L4_NORMAL_MAP_FROM || L4_NORMAL_SUB_MAP_FROM || \
     L5_NORMAL_MAP_FROM || L5_NORMAL_SUB_MAP_FROM || \
     L6_NORMAL_MAP_FROM || L6_NORMAL_SUB_MAP_FROM || \
     L7_NORMAL_MAP_FROM || L7_NORMAL_SUB_MAP_FROM)

// ==================== Normal Map Sampling Function ====================

float3 _sampleNormalMap(sampler src, float2 c, float loop, float scale, int type)
{
    float3 tn = tex2D(src, c * loop).rgb * 2 - 1;
    if (type == 1)
        tn.z = sqrt(1.0 - tn.x * tn.x - tn.y * tn.y);
    tn.rg *= scale;
    return normalize(tn);
}

// ==================== Sub-Albedo Blend Function ====================

float3 _albedoSubBlend(float3 base, float4 sub, int mode)
{
    float3 s = srgb2linear(sub.rgb);
    if (mode == 1) return base * s;
    if (mode == 2) return pow(max(base, 1e-5), s);
    if (mode == 3) return base + s;
    if (mode == 5) return lerp(base, s, sub.a);
    return base * s;
}

// ==================== Alpha Function (Shared) ====================

float GetAlpha(float2 coord)
{
#if ALPHA_MAP_FROM == 3
    float4 alphaValues = use_texture ? tex2D(DiffuseMapSamp, coord) * MaterialDiffuse.a : MaterialDiffuse.a;
    #if ALPHA_MAP_SWIZZLE == 0
        return saturate(alphaValues.r);
    #elif ALPHA_MAP_SWIZZLE == 1
        return saturate(alphaValues.g);
    #elif ALPHA_MAP_SWIZZLE == 2
        return saturate(alphaValues.b);
    #else
        return saturate(alphaValues.a);
    #endif
#else
    return saturate(MaterialDiffuse.a);
#endif
}

// ==================== Layer Parameter Arrays ====================
// Non-blendable parameters accessed by dominantLayer index

static const int layerShadingModel[8] = {
    L0_SHADING_MODEL, L1_SHADING_MODEL, L2_SHADING_MODEL,
    L3_SHADING_MODEL, L4_SHADING_MODEL, L5_SHADING_MODEL,
    L6_SHADING_MODEL, L7_SHADING_MODEL
};

static const float layerCustomA[8] = {
    (float)L0_CUSTOM_A, (float)L1_CUSTOM_A, (float)L2_CUSTOM_A,
    (float)L3_CUSTOM_A, (float)L4_CUSTOM_A, (float)L5_CUSTOM_A,
    (float)L6_CUSTOM_A, (float)L7_CUSTOM_A
};

static const float3 layerCustomB[8] = {
    (float3)L0_CUSTOM_B, (float3)L1_CUSTOM_B, (float3)L2_CUSTOM_B,
    (float3)L3_CUSTOM_B, (float3)L4_CUSTOM_B, (float3)L5_CUSTOM_B,
    (float3)L6_CUSTOM_B, (float3)L7_CUSTOM_B
};

static const float layerEmissiveIntensity[8] = {
    (float)L0_EMISSIVE_INTENSITY, (float)L1_EMISSIVE_INTENSITY, (float)L2_EMISSIVE_INTENSITY,
    (float)L3_EMISSIVE_INTENSITY, (float)L4_EMISSIVE_INTENSITY, (float)L5_EMISSIVE_INTENSITY,
    (float)L6_EMISSIVE_INTENSITY, (float)L7_EMISSIVE_INTENSITY
};

// ==================== Vertex Shader ====================

void MaterialVS(
    in  float4 Position  : POSITION,
    in  float3 Normal    : NORMAL,
    in  float2 Texcoord  : TEXCOORD0,
    out float3 oNormal   : TEXCOORD0,
    out float2 oTexcoord : TEXCOORD1,
    out float4 oWorldPos : TEXCOORD3,
    out float4 oPosition : POSITION)
{
    oNormal   = Normal;
    oTexcoord = Texcoord;
    oPosition = mul(Position, matWorldViewProject);
    oWorldPos = float4(Position.xyz, oPosition.w);
}

// ==================== Compositor Shared Logic ====================
// Blend processing shared between opaque and alpha passes

MaterialParam CompositeLayersMasked(float3 normal, float2 coord, float4 worldPos)
{
    normal = normalize(normal);

    // --- Model texture ---
    float3 baseTexColor;
    if (use_texture)
        baseTexColor = srgb2linear(tex2D(DiffuseMapSamp, coord).rgb * MaterialDiffuse.rgb);
    else
        baseTexColor = srgb2linear(MaterialDiffuse.rgb);

    // --- Mask sampling ---
    float m1 = 0, m2 = 0, m3 = 0, m4 = 0, m5 = 0, m6 = 0, m7 = 0;

    #if MASK_PACKING == 0
        // Individual grayscale masks
        #if LAYER_COUNT > 1
            m1 = tex2D(MaskSamp1, coord).r;
        #endif
        #if LAYER_COUNT > 2
            m2 = tex2D(MaskSamp2, coord).r;
        #endif
        #if LAYER_COUNT > 3
            m3 = tex2D(MaskSamp3, coord).r;
        #endif
        #if LAYER_COUNT > 4
            m4 = tex2D(MaskSamp4, coord).r;
        #endif
        #if LAYER_COUNT > 5
            m5 = tex2D(MaskSamp5, coord).r;
        #endif
        #if LAYER_COUNT > 6
            m6 = tex2D(MaskSamp6, coord).r;
        #endif
        #if LAYER_COUNT > 7
            m7 = tex2D(MaskSamp7, coord).r;
        #endif
    #else
        // RGBA packed masks
        #if LAYER_COUNT > 1
            float4 maskA = tex2D(MaskPackedSampA, coord);
            m1 = maskA.r;
            #if LAYER_COUNT > 2
                m2 = maskA.g;
            #endif
            #if LAYER_COUNT > 3
                m3 = maskA.b;
            #endif
            #if LAYER_COUNT > 4
                m4 = maskA.a;
            #endif
        #endif
        #if LAYER_COUNT > 5
            float4 maskB = tex2D(MaskPackedSampB, coord);
            m5 = maskB.r;
            #if LAYER_COUNT > 6
                m6 = maskB.g;
            #endif
            #if LAYER_COUNT > 7
                m7 = maskB.b;
            #endif
        #endif
    #endif

    // --- Weight calculation ---
    float maskSum = m1 + m2 + m3 + m4 + m5 + m6 + m7;
    float w0 = max(0.0, 1.0 - maskSum);
    float totalW = max(w0 + maskSum, 0.001);

    w0 /= totalW;
    float w1 = m1 / totalW;
    float w2 = m2 / totalW;
    float w3 = m3 / totalW;
    float w4 = m4 / totalW;
    float w5 = m5 / totalW;
    float w6 = m6 / totalW;
    float w7 = m7 / totalW;

    // --- Dominant layer (for non-blendable attributes) ---
    int dominantLayer = 0;
    float maxW = w0;

    #if LAYER_COUNT > 1
        if (w1 > maxW) { maxW = w1; dominantLayer = 1; }
    #endif
    #if LAYER_COUNT > 2
        if (w2 > maxW) { maxW = w2; dominantLayer = 2; }
    #endif
    #if LAYER_COUNT > 3
        if (w3 > maxW) { maxW = w3; dominantLayer = 3; }
    #endif
    #if LAYER_COUNT > 4
        if (w4 > maxW) { maxW = w4; dominantLayer = 4; }
    #endif
    #if LAYER_COUNT > 5
        if (w5 > maxW) { maxW = w5; dominantLayer = 5; }
    #endif
    #if LAYER_COUNT > 6
        if (w6 > maxW) { maxW = w6; dominantLayer = 6; }
    #endif
    #if LAYER_COUNT > 7
        if (w7 > maxW) { maxW = w7; dominantLayer = 7; }
    #endif

    // --- Albedo blend ---
    float3 blendedAlbedo = w0 * APPLY_ALBEDO_SUB(0, CALC_LAYER_ALBEDO(0, baseTexColor));
    #if LAYER_COUNT > 1
        blendedAlbedo += w1 * APPLY_ALBEDO_SUB(1, CALC_LAYER_ALBEDO(1, baseTexColor));
    #endif
    #if LAYER_COUNT > 2
        blendedAlbedo += w2 * APPLY_ALBEDO_SUB(2, CALC_LAYER_ALBEDO(2, baseTexColor));
    #endif
    #if LAYER_COUNT > 3
        blendedAlbedo += w3 * APPLY_ALBEDO_SUB(3, CALC_LAYER_ALBEDO(3, baseTexColor));
    #endif
    #if LAYER_COUNT > 4
        blendedAlbedo += w4 * APPLY_ALBEDO_SUB(4, CALC_LAYER_ALBEDO(4, baseTexColor));
    #endif
    #if LAYER_COUNT > 5
        blendedAlbedo += w5 * APPLY_ALBEDO_SUB(5, CALC_LAYER_ALBEDO(5, baseTexColor));
    #endif
    #if LAYER_COUNT > 6
        blendedAlbedo += w6 * APPLY_ALBEDO_SUB(6, CALC_LAYER_ALBEDO(6, baseTexColor));
    #endif
    #if LAYER_COUNT > 7
        blendedAlbedo += w7 * APPLY_ALBEDO_SUB(7, CALC_LAYER_ALBEDO(7, baseTexColor));
    #endif

    // --- Smoothness blend ---
    float blendedSmoothness = w0 * CALC_LAYER_SMOOTHNESS(0);
    #if LAYER_COUNT > 1
        blendedSmoothness += w1 * CALC_LAYER_SMOOTHNESS(1);
    #endif
    #if LAYER_COUNT > 2
        blendedSmoothness += w2 * CALC_LAYER_SMOOTHNESS(2);
    #endif
    #if LAYER_COUNT > 3
        blendedSmoothness += w3 * CALC_LAYER_SMOOTHNESS(3);
    #endif
    #if LAYER_COUNT > 4
        blendedSmoothness += w4 * CALC_LAYER_SMOOTHNESS(4);
    #endif
    #if LAYER_COUNT > 5
        blendedSmoothness += w5 * CALC_LAYER_SMOOTHNESS(5);
    #endif
    #if LAYER_COUNT > 6
        blendedSmoothness += w6 * CALC_LAYER_SMOOTHNESS(6);
    #endif
    #if LAYER_COUNT > 7
        blendedSmoothness += w7 * CALC_LAYER_SMOOTHNESS(7);
    #endif

    // --- Metalness blend ---
    float blendedMetalness = w0 * CALC_LAYER_METALNESS(0);
    #if LAYER_COUNT > 1
        blendedMetalness += w1 * CALC_LAYER_METALNESS(1);
    #endif
    #if LAYER_COUNT > 2
        blendedMetalness += w2 * CALC_LAYER_METALNESS(2);
    #endif
    #if LAYER_COUNT > 3
        blendedMetalness += w3 * CALC_LAYER_METALNESS(3);
    #endif
    #if LAYER_COUNT > 4
        blendedMetalness += w4 * CALC_LAYER_METALNESS(4);
    #endif
    #if LAYER_COUNT > 5
        blendedMetalness += w5 * CALC_LAYER_METALNESS(5);
    #endif
    #if LAYER_COUNT > 6
        blendedMetalness += w6 * CALC_LAYER_METALNESS(6);
    #endif
    #if LAYER_COUNT > 7
        blendedMetalness += w7 * CALC_LAYER_METALNESS(7);
    #endif

    // --- Specular blend ---
    float blendedSpecular = w0 * CALC_LAYER_SPECULAR(0);
    #if LAYER_COUNT > 1
        blendedSpecular += w1 * CALC_LAYER_SPECULAR(1);
    #endif
    #if LAYER_COUNT > 2
        blendedSpecular += w2 * CALC_LAYER_SPECULAR(2);
    #endif
    #if LAYER_COUNT > 3
        blendedSpecular += w3 * CALC_LAYER_SPECULAR(3);
    #endif
    #if LAYER_COUNT > 4
        blendedSpecular += w4 * CALC_LAYER_SPECULAR(4);
    #endif
    #if LAYER_COUNT > 5
        blendedSpecular += w5 * CALC_LAYER_SPECULAR(5);
    #endif
    #if LAYER_COUNT > 6
        blendedSpecular += w6 * CALC_LAYER_SPECULAR(6);
    #endif
    #if LAYER_COUNT > 7
        blendedSpecular += w7 * CALC_LAYER_SPECULAR(7);
    #endif

    // --- Occlusion blend ---
    float blendedOcclusion = w0 * CALC_LAYER_OCCLUSION(0);
    #if LAYER_COUNT > 1
        blendedOcclusion += w1 * CALC_LAYER_OCCLUSION(1);
    #endif
    #if LAYER_COUNT > 2
        blendedOcclusion += w2 * CALC_LAYER_OCCLUSION(2);
    #endif
    #if LAYER_COUNT > 3
        blendedOcclusion += w3 * CALC_LAYER_OCCLUSION(3);
    #endif
    #if LAYER_COUNT > 4
        blendedOcclusion += w4 * CALC_LAYER_OCCLUSION(4);
    #endif
    #if LAYER_COUNT > 5
        blendedOcclusion += w5 * CALC_LAYER_OCCLUSION(5);
    #endif
    #if LAYER_COUNT > 6
        blendedOcclusion += w6 * CALC_LAYER_OCCLUSION(6);
    #endif
    #if LAYER_COUNT > 7
        blendedOcclusion += w7 * CALC_LAYER_OCCLUSION(7);
    #endif

    // --- Emissive blend ---
    float3 blendedEmissive = w0 * CALC_LAYER_EMISSIVE(0);
    #if LAYER_COUNT > 1
        blendedEmissive += w1 * CALC_LAYER_EMISSIVE(1);
    #endif
    #if LAYER_COUNT > 2
        blendedEmissive += w2 * CALC_LAYER_EMISSIVE(2);
    #endif
    #if LAYER_COUNT > 3
        blendedEmissive += w3 * CALC_LAYER_EMISSIVE(3);
    #endif
    #if LAYER_COUNT > 4
        blendedEmissive += w4 * CALC_LAYER_EMISSIVE(4);
    #endif
    #if LAYER_COUNT > 5
        blendedEmissive += w5 * CALC_LAYER_EMISSIVE(5);
    #endif
    #if LAYER_COUNT > 6
        blendedEmissive += w6 * CALC_LAYER_EMISSIVE(6);
    #endif
    #if LAYER_COUNT > 7
        blendedEmissive += w7 * CALC_LAYER_EMISSIVE(7);
    #endif

    // --- Emissive intensity blend ---
    float blendedEmissiveIntensity =
        w0 * layerEmissiveIntensity[0]
    #if LAYER_COUNT > 1
      + w1 * layerEmissiveIntensity[1]
    #endif
    #if LAYER_COUNT > 2
      + w2 * layerEmissiveIntensity[2]
    #endif
    #if LAYER_COUNT > 3
      + w3 * layerEmissiveIntensity[3]
    #endif
    #if LAYER_COUNT > 4
      + w4 * layerEmissiveIntensity[4]
    #endif
    #if LAYER_COUNT > 5
      + w5 * layerEmissiveIntensity[5]
    #endif
    #if LAYER_COUNT > 6
      + w6 * layerEmissiveIntensity[6]
    #endif
    #if LAYER_COUNT > 7
      + w7 * layerEmissiveIntensity[7]
    #endif
    ;

    // --- Normal blend ---
    // Weighted blend of each layer's tangent-space normal
    float3 blendedNormal;

#if _ANY_NORMAL_MAP
    float3 blendedTangentNormal = w0 * CALC_LAYER_TANGENT_NORMAL(0);
    #if LAYER_COUNT > 1
        blendedTangentNormal += w1 * CALC_LAYER_TANGENT_NORMAL(1);
    #endif
    #if LAYER_COUNT > 2
        blendedTangentNormal += w2 * CALC_LAYER_TANGENT_NORMAL(2);
    #endif
    #if LAYER_COUNT > 3
        blendedTangentNormal += w3 * CALC_LAYER_TANGENT_NORMAL(3);
    #endif
    #if LAYER_COUNT > 4
        blendedTangentNormal += w4 * CALC_LAYER_TANGENT_NORMAL(4);
    #endif
    #if LAYER_COUNT > 5
        blendedTangentNormal += w5 * CALC_LAYER_TANGENT_NORMAL(5);
    #endif
    #if LAYER_COUNT > 6
        blendedTangentNormal += w6 * CALC_LAYER_TANGENT_NORMAL(6);
    #endif
    #if LAYER_COUNT > 7
        blendedTangentNormal += w7 * CALC_LAYER_TANGENT_NORMAL(7);
    #endif

    blendedTangentNormal = normalize(blendedTangentNormal);
    blendedNormal = ComputeTangentBinormalNormal(normal, worldPos.xyz, coord, blendedTangentNormal);
#else
    blendedNormal = normal;
#endif

    // --- Build material ---
    MaterialParam material;
    material.albedo            = saturate(blendedAlbedo);
    material.normal            = blendedNormal;
    material.smoothness        = saturate(blendedSmoothness);
    material.metalness         = saturate(blendedMetalness);
    material.specular          = saturate(0.08 * blendedSpecular);
    material.emissive          = blendedEmissive;
    material.emissiveIntensity = blendedEmissiveIntensity;
    material.visibility        = saturate(blendedOcclusion);
    material.alpha             = 1.0;

    // Non-blendable attributes: take from dominant (max weight) layer
    material.customDataA = layerCustomA[dominantLayer];
    material.customDataB = layerCustomB[dominantLayer];

    // Determine shading model
    if (any(saturate(material.emissive - EMISSIVE_EPSILON)))
        material.lightModel = SHADINGMODELID_EMISSIVE;
    else
        material.lightModel = layerShadingModel[dominantLayer];

    return material;
}

// ==================== Pixel Shader (Opaque) ====================

GbufferParam CompositorPS(
    in float3 normal   : TEXCOORD0,
    in float2 coord    : TEXCOORD1,
    in float4 worldPos : TEXCOORD3)
{
    float alpha = GetAlpha(coord);
    clip(alpha - ALPHA_THRESHOLD);

    MaterialParam material = CompositeLayersMasked(normal, coord, worldPos);
    return EncodeGbufferMasked(material, worldPos.w);
}

// ==================== Pixel Shader (Alpha) ====================

GbufferParam CompositorAlphaPS(
    in float3 normal   : TEXCOORD0,
    in float2 coord    : TEXCOORD1,
    in float4 worldPos : TEXCOORD3)
{
    float alpha = GetAlpha(coord);
    clip(alpha - 0.01);

    MaterialParam material = CompositeLayersMasked(normal, coord, worldPos);
    material.alpha = (alpha > ALPHA_THRESHOLD) ? 0 : alpha;

    return EncodeGbufferMasked(material, worldPos.w);
}

// ==================== Techniques ====================

#define OBJECT_TEC(name, mmdpass) \
    technique name < string MMDPass = mmdpass; \
    string Script = \
        "RenderColorTarget0=;" \
        "RenderColorTarget1=Gbuffer2RT;" \
        "RenderColorTarget2=Gbuffer3RT;" \
        "RenderColorTarget3=Gbuffer4RT;" \
        "Pass=DrawObject;" \
        "RenderColorTarget0=Gbuffer5RT;" \
        "RenderColorTarget1=Gbuffer6RT;" \
        "RenderColorTarget2=Gbuffer7RT;" \
        "RenderColorTarget3=Gbuffer8RT;" \
        "Pass=DrawAlphaObject;" \
    ; > { \
        pass DrawObject { \
            AlphaTestEnable = false; AlphaBlendEnable = false; \
            VertexShader = compile vs_3_0 MaterialVS(); \
            PixelShader  = compile ps_3_0 CompositorPS(); \
        } \
        pass DrawAlphaObject { \
            AlphaTestEnable = false; AlphaBlendEnable = false; \
            VertexShader = compile vs_3_0 MaterialVS(); \
            PixelShader  = compile ps_3_0 CompositorAlphaPS(); \
        } \
    }

OBJECT_TEC(MainTec0, "object")
OBJECT_TEC(MainTecBS0, "object_ss")

technique EdgeTec   < string MMDPass = "edge"; > {}
technique ShadowTech < string MMDPass = "shadow"; > {}
technique ZplotTec  < string MMDPass = "zplot"; > {}
