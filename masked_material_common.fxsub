        (srgb2linear(tex2D(L2_AlbedoTexSamp, coord).rgb) * srgb2linear((float3)L2_ALBEDO))
#elif L2_ALBEDO_APPLY_DIFFUSE
    #define _CALC_LAYER_ALBEDO_2(baseTex) \
        ((baseTex) * srgb2linear((float3)L2_ALBEDO))
#else
    #define _CALC_LAYER_ALBEDO_2(baseTex) \
        (srgb2linear((float3)L2_ALBEDO))
#endif

