// ============================================================
// masked_material_common.fxsub
// Mask-based multi-layer material - Core shader
//
// ray-mmd material_common_2.0.fxsub compatible G-Buffer output
// Per-layer texture map support
// ============================================================

// ==================== Validation ====================

#ifndef LAYER_COUNT
    #define LAYER_COUNT 2
#endif

#ifndef MASK_PACKING
    #define _MASK_PACKING_EARLY 0
#else
    #define _MASK_PACKING_EARLY MASK_PACKING
#endif

#if _MASK_PACKING_EARLY == 0
    #if LAYER_COUNT < 2 || LAYER_COUNT > 6
        #error LAYER_COUNT must be in range 2-6 (MASK_PACKING=0)
    #endif
#else
    #if LAYER_COUNT < 2 || LAYER_COUNT > 8
        #error LAYER_COUNT must be in range 2-8 (MASK_PACKING=1)
    #endif
#endif

// ==================== Constants ====================

#define MIDPOINT_8_BIT        (127.0f / 255.0f)
#define MAX_FRACTIONAL_8_BIT  (255.0f / 256.0f)
#define EMISSIVE_EPSILON      (2.0f / 255.0f)
#define ALPHA_THRESHOLD       0.999

#define SHADINGMODELID_DEFAULT    0
#define SHADINGMODELID_SKIN       1
#define SHADINGMODELID_EMISSIVE   2
#define SHADINGMODELID_ANISOTROPY 3
#define SHADINGMODELID_GLASS      4
#define SHADINGMODELID_CLOTH      5
#define SHADINGMODELID_CLEAR_COAT 6
#define SHADINGMODELID_SUBSURFACE 7
#define SHADINGMODELID_CEL        8
#define SHADINGMODELID_TONEBASED  9

// ==================== Layer Default Values ====================
// Set default values for undefined parameters.
// Covers base material properties + texture map settings per layer.

// ====================================================================
// Default value definitions via macros
// HLSL preprocessor does not allow #ifndef inside #define,
// so each layer x parameter must be enumerated individually.
// ====================================================================

